@import url('https://fonts.googleapis.com/css2?family=Orbitron:wght@400;500;700;900&display=swap');

/* RESET BASE */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

body {
  font-family: 'Orbitron', sans-serif;
  background: #050814;
  color: #e0f7fa;
  min-height: 100vh;
  overflow-x: hidden;
  position: relative;
}

/* CYBERPUNK BACKGROUND GRID (Optional subtle effect) */
body::before {
  content: "";
  position: absolute;
  inset: 0;
  background-image:
    linear-gradient(rgba(0, 255, 255, 0.03) 1px, transparent 1px),
    linear-gradient(90deg, rgba(0, 255, 255, 0.03) 1px, transparent 1px);
  background-size: 30px 30px;
  pointer-events: none;
  z-index: -1;
}

/* LAYOUT */
.layout {
  display: flex;
  flex-direction: column;
  min-height: 100vh;
}

/* ========== TOP NAVBAR ========== */
.navbar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 15px 40px;
  background: rgba(2, 6, 23, 0.8);
  backdrop-filter: blur(10px);
  border-bottom: 1px solid rgba(0, 255, 255, 0.2);
  box-shadow: 0 4px 30px rgba(0, 255, 255, 0.1);
  z-index: 100;
  position: sticky;
  top: 0;
}

.navbar-logo {
  display: flex;
  align-items: center;
  gap: 15px;
}

.navbar-logo img {
  width: 40px;
  filter: drop-shadow(0 0 8px rgba(0, 255, 255, 0.8));
}

.navbar-logo h1 {
  font-size: 1.2rem;
  letter-spacing: 2px;
  color: #38bdf8;
  text-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
  margin: 0;
  text-transform: uppercase;
}

/* MENU BASE */
.menu {
  display: flex;
  gap: 30px;
  align-items: center;
}

.menu-group {
  position: relative;
}

/* LINK E BUTTON IDENTICI */
.menu-link,
.menu-toggle {
  all: unset;
  display: flex;
  align-items: center;
  gap: 8px;
  font-size: 0.9rem;
  font-weight: 500;
  color: #a5f3fc;
  cursor: pointer;
  letter-spacing: 1px;
  text-transform: uppercase;
  transition: all 0.3s ease;
  padding: 8px 12px;
  border-radius: 4px;
}

.menu-link:hover,
.menu-toggle:hover {
  color: #38bdf8;
  text-shadow: 0 0 8px rgba(0, 255, 255, 0.8);
  background: rgba(0, 255, 255, 0.1);
  box-shadow: inset 0 0 10px rgba(0, 255, 255, 0.2);
}

.menu-link.active {
  color: #38bdf8;
  text-shadow: 0 0 10px rgba(0, 255, 255, 0.8);
  border-bottom: 2px solid #38bdf8;
}

/* ICONE */
.icon {
  display: none;
  /* Hide icons in top nav for cleaner look, or keep them if preferred */
}

/* FRECCIA */
.arrow {
  font-size: 0.7em;
  transition: transform 0.3s ease;
}

/* SOTTOMENU (DROPDOWN) */
.menu-group .menu-content {
  position: absolute;
  top: 100%;
  left: 0;
  background: rgba(2, 6, 23, 0.95);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(0, 255, 255, 0.2);
  border-top: none;
  min-width: 200px;
  display: none;
  flex-direction: column;
  padding: 10px 0;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
  border-radius: 0 0 8px 8px;
  z-index: 100;
}

.menu-group:hover>.menu-content,
.menu-group.open>.menu-content {
  display: flex;
}

.menu-group:hover>.menu-toggle .arrow,
.menu-group.open>.menu-toggle .arrow {
  transform: rotate(180deg);
}

.menu-content .menu-link {
  padding: 10px 20px;
  font-size: 0.8rem;
  border-radius: 0;
}

.menu-content .menu-link:hover {
  background: rgba(0, 255, 255, 0.15);
  border-left: 3px solid #38bdf8;
}

/* CLOCK */
.digital-clock {
  font-weight: 700;
  color: #38bdf8;
  text-shadow: 0 0 8px rgba(0, 255, 255, 0.6);
  letter-spacing: 2px;
  font-size: 1.1rem;
  display: inline-block;
  width: 115px;
  flex-shrink: 0;
  text-align: right;
  font-variant-numeric: tabular-nums;
}

/* ========== MAIN ========== */
.main {
  flex: 1;
  position: relative;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  /* Center content vertically */
  padding: 40px 20px;
  overflow: hidden;
}

/* ========== 3D HERO LOGO ========== */
.hero-logo-container {
  perspective: 1000px;
  margin-bottom: 40px;
  position: relative;
  z-index: 2;
  display: flex;
  justify-content: center;
  align-items: center;
}

.hero-logo {
  width: 300px;
  height: 300px;
  object-fit: contain;
  filter: drop-shadow(0 0 20px rgba(0, 255, 255, 0.6)) drop-shadow(0 0 40px rgba(0, 150, 255, 0.4));
  transform-style: preserve-3d;
  animation: rotate3d 15s linear infinite;
  transition: transform 0.1s;
  /* For mousemove effect */
}

/* Optional glowing rings behind logo */
.hero-logo-container::before,
.hero-logo-container::after {
  content: "";
  position: absolute;
  border-radius: 50%;
  border: 2px solid rgba(0, 255, 255, 0.3);
  top: 50%;
  left: 50%;
  transform: translate(-50%, -50%);
  pointer-events: none;
}

.hero-logo-container::before {
  width: 400px;
  height: 400px;
  border-top-color: rgba(0, 255, 255, 0.8);
  animation: spin 10s linear infinite;
}

.hero-logo-container::after {
  width: 450px;
  height: 450px;
  border-bottom-color: rgba(0, 150, 255, 0.8);
  border-left-color: rgba(0, 150, 255, 0.5);
  animation: spin-reverse 15s linear infinite;
}

@keyframes rotate3d {
  0% {
    transform: rotateY(0deg) rotateX(10deg);
  }

  50% {
    transform: rotateY(180deg) rotateX(-10deg);
    filter: drop-shadow(0 0 30px rgba(0, 255, 255, 0.8)) drop-shadow(0 0 60px rgba(0, 150, 255, 0.6));
  }

  100% {
    transform: rotateY(360deg) rotateX(10deg);
  }
}

@keyframes spin {
  0% {
    transform: translate(-50%, -50%) rotate(0deg);
  }

  100% {
    transform: translate(-50%, -50%) rotate(360deg);
  }
}

@keyframes spin-reverse {
  0% {
    transform: translate(-50%, -50%) rotate(360deg);
  }

  100% {
    transform: translate(-50%, -50%) rotate(0deg);
  }
}


/* ========== CARDS ========== */

.cards {
  display: flex;
  gap: 30px;
  position: relative;
  z-index: 10;
  max-width: 800px;
  width: 100%;
  justify-content: center;
  flex-wrap: wrap;
}

.card {
  background: rgba(2, 6, 23, 0.6);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(0, 255, 255, 0.3);
  padding: 30px;
  border-radius: 12px;
  text-decoration: none;
  color: inherit;
  box-shadow: 0 0 20px rgba(0, 0, 0, 0.5), inset 0 0 15px rgba(0, 255, 255, 0.05);
  transition: all 0.3s ease;
  flex: 1;
  min-width: 250px;
  text-align: center;
  position: relative;
  overflow: hidden;
}

/* Card Hover Glow Effect */
.card::before {
  content: "";
  position: absolute;
  top: 0;
  left: -100%;
  width: 50%;
  height: 100%;
  background: linear-gradient(to right, transparent, rgba(0, 255, 255, 0.1), transparent);
  transform: skewX(-20deg);
  transition: 0.5s;
}

.card:hover::before {
  left: 150%;
}

.card:hover {
  transform: translateY(-10px) scale(1.02);
  border-color: rgba(0, 255, 255, 0.8);
  box-shadow: 0 0 30px rgba(0, 255, 255, 0.2), inset 0 0 20px rgba(0, 255, 255, 0.1);
}

.card h3 {
  margin-bottom: 10px;
  font-size: 1.5rem;
  color: #38bdf8;
  letter-spacing: 1px;
  text-shadow: 0 0 5px rgba(0, 255, 255, 0.5);
}

.card p {
  color: #94a3b8;
  font-size: 0.9rem;
  line-height: 1.5;
}

.card.finance {
  border-top: 3px solid #2563eb;
}

.card.finance:hover {
  border-color: #2563eb;
  box-shadow: 0 0 30px rgba(37, 99, 235, 0.3);
}

.card.finance h3 {
  color: #60a5fa;
  text-shadow: 0 0 5px rgba(37, 99, 235, 0.5);
}

.card.engineering {
  border-top: 3px solid #f97316;
}

.card.engineering:hover {
  border-color: #f97316;
  box-shadow: 0 0 30px rgba(249, 115, 22, 0.3);
}

.card.engineering h3 {
  color: #fb923c;
  text-shadow: 0 0 5px rgba(249, 115, 22, 0.5);
}

.card.personal {
  border-top: 3px solid #8b5cf6;
  /* Cyber Purple */
}

.card.personal:hover {
  border-color: #8b5cf6;
  box-shadow: 0 0 30px rgba(139, 92, 246, 0.3);
}

.card.personal h3 {
  color: #a78bfa;
  text-shadow: 0 0 5px rgba(139, 92, 246, 0.5);
}


/* Hide old classes that are no longer used in the new layout */
.background-logo,
.sidebar {
  display: none !important;
}

/* ========== TIMELINE ========== */
.timeline {
  position: relative;
  max-width: 800px;
  margin: 0 auto;
  padding: 20px 0;
}

.timeline::after {
  content: '';
  position: absolute;
  width: 4px;
  background: rgba(0, 255, 255, 0.3);
  top: 0;
  bottom: 0;
  left: 20px;
  margin-left: -2px;
  box-shadow: 0 0 10px rgba(0, 255, 255, 0.5);
  border-radius: 2px;
}

.timeline-item {
  padding: 10px 40px;
  position: relative;
  background: inherit;
  width: 100%;
}

.timeline-item::after {
  content: '';
  position: absolute;
  width: 16px;
  height: 16px;
  right: auto;
  background-color: #050814;
  border: 4px solid #38bdf8;
  top: 15px;
  border-radius: 50%;
  z-index: 1;
  left: 20px;
  margin-left: -8px;
  box-shadow: 0 0 10px #38bdf8;
}

.timeline-content {
  padding: 20px;
  background: rgba(2, 6, 23, 0.6);
  backdrop-filter: blur(10px);
  border: 1px solid rgba(0, 255, 255, 0.3);
  border-radius: 8px;
  position: relative;
  box-shadow: 0 0 20px rgba(0, 0, 0, 0.5), inset 0 0 15px rgba(0, 255, 255, 0.05);
  transition: all 0.3s ease;
}

.timeline-content:hover {
  transform: translateX(10px);
  border-color: rgba(0, 255, 255, 0.8);
  box-shadow: 0 0 30px rgba(0, 255, 255, 0.2), inset 0 0 20px rgba(0, 255, 255, 0.1);
}

.timeline-date {
  color: #38bdf8;
  font-weight: bold;
  margin-bottom: 5px;
  display: block;
  font-size: 0.9rem;
  text-shadow: 0 0 5px rgba(0, 255, 255, 0.5);
}

.timeline-title {
  color: #e0f7fa;
  font-size: 1.1rem;
  margin-bottom: 5px;
}

.timeline-desc {
  color: #94a3b8;
  font-size: 0.9rem;
  line-height: 1.5;
}

.timeline-item.active::after {
  background-color: #facc15;
  border-color: #facc15;
  box-shadow: 0 0 15px #facc15, 0 0 30px #facc15;
}

.timeline-item.active .timeline-content {
  border-color: #facc15;
  box-shadow: 0 0 20px rgba(250, 204, 21, 0.2), inset 0 0 10px rgba(250, 204, 21, 0.1);
}

.timeline-item.active .timeline-content:hover {
  border-color: #fef08a;
  box-shadow: 0 0 30px rgba(250, 204, 21, 0.4), inset 0 0 20px rgba(250, 204, 21, 0.2);
}

@media (max-width: 768px) {
  .navbar {
    flex-direction: column;
    gap: 15px;
    padding: 15px;
  }

  .menu {
    flex-wrap: wrap;
    justify-content: center;
    gap: 15px;
  }

  .hero-logo-container::before {
    width: 300px;
    height: 300px;
  }

  .hero-logo-container::after {
    width: 350px;
    height: 350px;
  }

  .hero-logo {
    width: 200px;
    height: 200px;
  }
}

.input-label {
  color: #e2e8f0;
}

/* ========== LIGHT MODE ========== */
body.light-mode {
  background: #f8fafc !important;
  color: #1e293b !important;
}

body.light-mode .input-label {
  color: #1e293b !important;
}

body.light-mode::before {
  background-image:
    linear-gradient(rgba(14, 165, 233, 0.1) 1px, transparent 1px),
    linear-gradient(90deg, rgba(14, 165, 233, 0.1) 1px, transparent 1px) !important;
  opacity: 0.5;
  /* Rende la griglia meno invadente sul bianco, ma oscura l'originale */
}

body.light-mode .navbar {
  background: rgba(241, 245, 249, 0.85) !important;
  border-bottom: 1px solid rgba(14, 165, 233, 0.3) !important;
  box-shadow: 0 4px 30px rgba(14, 165, 233, 0.15) !important;
}

body.light-mode .navbar-logo h1 {
  color: #0284c7 !important;
  text-shadow: none !important;
}

body.light-mode .navbar-logo img {
  filter: drop-shadow(0 0 8px rgba(14, 165, 233, 0.5)) !important;
}

body.light-mode .menu-link,
body.light-mode .menu-toggle {
  color: #334155 !important;
}

body.light-mode .menu-link:hover,
body.light-mode .menu-toggle:hover {
  color: #0284c7 !important;
  text-shadow: none !important;
  background: rgba(14, 165, 233, 0.1) !important;
  box-shadow: none !important;
}

body.light-mode .menu-link.active {
  color: #0284c7 !important;
  text-shadow: none !important;
  border-bottom: 2px solid #0284c7 !important;
}

body.light-mode .menu-group .menu-content {
  background: rgba(248, 250, 252, 0.95) !important;
  border: 1px solid rgba(14, 165, 233, 0.3) !important;
  box-shadow: 0 10px 30px rgba(0, 0, 0, 0.1) !important;
}

body.light-mode .menu-content .menu-link:hover {
  background: rgba(14, 165, 233, 0.15) !important;
  border-left: 3px solid #0284c7 !important;
}

body.light-mode .digital-clock {
  color: #0284c7 !important;
  text-shadow: none !important;
}

body.light-mode .hero-logo {
  filter: drop-shadow(0 0 20px rgba(14, 165, 233, 0.4)) drop-shadow(0 0 40px rgba(2, 132, 199, 0.2)) !important;
}

body.light-mode .card {
  background: rgba(255, 255, 255, 0.7) !important;
  border: 1px solid rgba(14, 165, 233, 0.3) !important;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05) !important;
  color: #334155 !important;
}

body.light-mode .card h3 {
  color: #0284c7 !important;
  text-shadow: none !important;
}

body.light-mode .card p {
  color: #475569 !important;
}

body.light-mode .contact-email {
  color: #0284c7 !important;
  border-color: #0284c7 !important;
  background: rgba(2, 132, 199, 0.1) !important;
  box-shadow: 0 0 15px rgba(2, 132, 199, 0.2) !important;
}

body.light-mode .card:hover {
  border-color: rgba(14, 165, 233, 0.8) !important;
  box-shadow: 0 10px 25px rgba(14, 165, 233, 0.2) !important;
}

body.light-mode .timeline-content {
  background: rgba(255, 255, 255, 0.7) !important;
  border: 1px solid rgba(14, 165, 233, 0.3) !important;
  box-shadow: 0 5px 15px rgba(0, 0, 0, 0.05) !important;
}

body.light-mode .timeline-content:hover {
  border-color: rgba(14, 165, 233, 0.8) !important;
  box-shadow: 0 10px 25px rgba(14, 165, 233, 0.2) !important;
}

body.light-mode .timeline-title {
  color: #1e293b !important;
}

body.light-mode .timeline-desc {
  color: #475569 !important;
}

body.light-mode .timeline-date {
  color: #0284c7 !important;
  text-shadow: none !important;
}

body.light-mode .timeline::after {
  background: rgba(14, 165, 233, 0.3) !important;
  box-shadow: none !important;
}

body.light-mode .timeline-item::after {
  background-color: #f8fafc !important;
  border-color: #0284c7 !important;
  box-shadow: none !important;
}

/* Fix Card Personale inline styles override in light mode */
body.light-mode .card.personal h2 {
  color: #0284c7 !important;
}

body.light-mode .card.personal h3 {
  color: #6d28d9 !important;
  text-shadow: none !important;
  border-bottom-color: rgba(109, 40, 217, 0.2) !important;
}

body.light-mode .card.personal h4 {
  color: #1e293b !important;
}

body.light-mode .card.personal p,
body.light-mode .card.personal ul {
  color: #334155 !important;
}

body.light-mode .card.personal span,
body.light-mode .card.personal a {
  color: #0284c7 !important;
  border-color: rgba(2, 132, 199, 0.3) !important;
  background: rgba(2, 132, 199, 0.1) !important;
}

body.light-mode .card.personal h4 span {
  color: #64748b !important;
  background: transparent !important;
  border: none !important;
  font-weight: normal;
}

body.light-mode .card.personal ul li strong {
  color: #0284c7 !important;
}

body.light-mode .card.personal div>span {
  color: #0284c7 !important;
  background: transparent !important;
  border: none !important;
}

body.light-mode .card.personal table {
  color: #334155 !important;
}

body.light-mode .card.personal th {
  color: #6d28d9 !important;
  border-bottom-color: rgba(109, 40, 217, 0.3) !important;
}

body.light-mode .card.personal td {
  color: #475569 !important;
  border-bottom-color: rgba(0, 0, 0, 0.05) !important;
}

body.light-mode .card.personal tr[style*="background"] td {
  background: rgba(109, 40, 217, 0.03) !important;
}

body.light-mode .card.personal td[style*="color: #38bdf8"] {
  color: #0284c7 !important;
  font-weight: bold;
}

body.light-mode .card.personal td[style*="color: #fcd34d"] {
  color: #d97706 !important;
  text-shadow: none !important;
}

body.light-mode .card.personal td[style*="-webkit-text-fill-color"] {
  background: transparent !important;
  color: #b45309 !important;
  -webkit-text-fill-color: initial !important;
  text-shadow: none !important;
}

body.light-mode .card.personal td[style*="color: #e0f7fa"] {
  color: #0f172a !important;
  font-weight: bold;
}

body.light-mode .card.personal td[style*="color: #22c55e"] {
  color: #16a34a !important;
  font-weight: bold;
}

/* Timeline Gold Highlight - DARK MODE */
.timeline-item.gold-highlight .timeline-content {
  border: 2px solid rgba(250, 204, 21, 0.6);
  box-shadow: 0 0 15px rgba(250, 204, 21, 0.3);
}

.timeline-item.gold-highlight .timeline-date {
  color: #facc15 !important;
  text-shadow: 0 0 5px rgba(250, 204, 21, 0.5) !important;
}

.timeline-item.gold-highlight .timeline-title {
  color: #fef08a !important;
  text-shadow: 0 0 8px rgba(250, 204, 21, 0.3) !important;
}

.timeline-item.gold-highlight::after {
  background-color: #facc15 !important;
  border-color: #fef08a !important;
  box-shadow: 0 0 10px rgba(250, 204, 21, 0.6) !important;
}

/* Timeline Gold Highlight - LIGHT MODE */
body.light-mode .timeline-item.gold-highlight .timeline-content {
  border: 2px solid rgba(202, 138, 4, 0.8) !important;
  box-shadow: 0 5px 15px rgba(202, 138, 4, 0.2) !important;
  background: #fefce8 !important;
  /* light yellow */
}

body.light-mode .timeline-item.gold-highlight .timeline-title {
  color: #a16207 !important;
  /* dark gold */
  text-shadow: none !important;
}

body.light-mode .timeline-item.gold-highlight .timeline-date {
  color: #ca8a04 !important;
  /* solid gold */
  font-weight: bold;
}

body.light-mode .timeline-item.gold-highlight::after {
  background-color: #facc15 !important;
  border-color: #a16207 !important;
  box-shadow: 0 0 8px rgba(202, 138, 4, 0.4) !important;
}

/* Transitions for smooth theme switching */
body,
.navbar,
.card,
.menu-content,
.timeline-content {
  transition: background-color 0.5s ease, color 0.5s ease, border-color 0.5s ease, box-shadow 0.5s ease;
}

.hero-logo,
.navbar-logo h1,
.navbar-logo img,
.menu-link,
.menu-toggle,
.digital-clock,
.card h3,
.card p,
.timeline-title,
.timeline-desc,
.timeline-date {
  transition: color 0.5s ease, text-shadow 0.5s ease, filter 0.5s ease;
}

body.light-mode {
  background-color: #f8fafc !important;
}

body.light-mode .layout {
  background: transparent !important;
}

body.light-mode .main {
  background: transparent !important;
}
